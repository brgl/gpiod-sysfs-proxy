[Unit]
Description=Remount of sysfs for gpiod-sysfs-proxy
PartOf=gpiod-sysfs-proxy@sys-class-gpio.service
ConditionPathExists=!/sys/class/gpio

[Mount]
DirectoryMode=0700
What=sysfs
Where=/run/gpio/sys
Type=sysfs
Options=nosuid,nodev,noexec
